rozitech_pos/pubspec.lock

# Flutter Android/iOS build files
rozitech_pos/android/local.properties
rozitech_pos/android/key.properties
rozitech_pos/ios/Flutter/Generated.xcconfig
rozitech_pos/ios/Flutter/flutter_export_environment.sh

