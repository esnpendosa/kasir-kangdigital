kangdigital_web/storage/*.key
kangdigital_web/storage/framework/cache/data/*
!kangdigital_web/storage/framework/cache/data/.gitkeep
kangdigital_web/storage/framework/sessions/*
!kangdigital_web/storage/framework/sessions/.gitkeep
kangdigital_web/storage/framework/testing/*
!kangdigital_web/storage/framework/testing/.gitkeep
kangdigital_web/storage/framework/views/*
!kangdigital_web/storage/framework/views/.gitkeep
kangdigital_web/storage/logs/*
!kangdigital_web/storage/logs/.gitkeep
kangdigital_web/public/storage

# Flutter - Mobile POS gitignore
rozitech_pos/.dart_tool/
rozitech_pos/build/
rozitech_pos/.flutter-plugins
